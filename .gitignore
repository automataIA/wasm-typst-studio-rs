# ============================================
# Rust Build Artifacts
# ============================================
target
debug
release
Cargo.lock

# ============================================
# Backup and Temporary Files
# ============================================
*.backup
*.bak
*.old
*.tmp
*.temp
*~
*.orig
*.rej
*.swp
*.swo

# ============================================
# Logs and Debugging
# ============================================
*.log
logs/
*.prof
*.out
*.trace

# ============================================
# OS Specific
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*

# ============================================
# Editor and IDE
# ============================================
# IntelliJ IDEA / CLion / RustRover
.idea/
*.iml
*.ipr
*.iws
.idea_modules/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# Emacs
\#*\#
.#*
*~
*.elc

# JetBrains
.fleet/

# ============================================
# Environment and Configuration
# ============================================
.env
.env.local
.env.*.local
*.secret
secrets/
# Rust compiler crash dumps
rustc-ice-*.txt
*.key
*.pem
*.crt
*.p12
credentials.json

# ============================================
# Dependencies and Node (for WASM projects)
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.pnpm-debug.log*

# ============================================
# WASM Build Artifacts
# ============================================
/dist
/pkg
wasm-pack.log

# ============================================
# Tauri Desktop Bundles
# ============================================
WixTools/
*.app
*.dmg
*.AppImage
*.deb
*.msi
*.pdb

# ============================================
# Test and Coverage
# ============================================
*.profraw
*.profdata
coverage/
tarpaulin-report.html
cobertura.xml
lcov.info

# ============================================
# Database Files
# ============================================
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# ============================================
# Benchmarking and Profiling
# ============================================
criterion/
flamegraph.svg
perf.data
perf.data.old

# ============================================
# Project Specific
# ============================================
# Config examples are kept, but instance configs are ignored
*_local.toml
*_private.toml
my_*.toml
# Tailwind CLI output (generated by Trunk's pre_build hook from tailwind.css)
tailwind.gen.css
/info
/vendor
# ============================================
# Hidden Files and Folders (Root Directory)
# ============================================
# Exclude all hidden files/folders, then exceptions below
.*
*.md
/.*.json
# ============================================
# Exceptions (Keep These)
# ============================================
!.github/
!.vscode/
!README.md
!CHANGELOG.md
!CHANGELOG_TAURI.md
!QUICK_START.md
!TAURI_INTEGRATION.md
!LICENSE
!Cargo.lock
!.gitignore
!.cargo/
/docs
target_tmp/CACHEDIR.TAG
crates/lodviz_core/target_clippy/CACHEDIR.TAG
apps/web_dashboard/dist/
kuva/
tests/
pi/

# Keep the E2E smoke suite (dev tooling) tracked even though `tests/` is ignored
# above; generated run artefacts stay out.
!tests/
!tests/e2e/
!tests/e2e/*.mjs
!tests/e2e/*.sh
tests/e2e/screenshots/
tests/e2e/snapshots/
tests/e2e/state/
