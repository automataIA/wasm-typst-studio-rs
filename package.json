{
  "name": "wasm-typst-studio-rs",
  "version": "0.2.0",
  "description": "Pure Rust WASM Typst Studio with Tailwind CSS 4",
  "scripts": {
    "dev": "trunk serve",
    "build": "trunk build --release",
    "build:optimized": "trunk build --release && ./scripts/compress-wasm.sh",
    "tauri:dev": "cargo tauri dev",
    "tauri:build": "cargo tauri build",
    "size-report": "./scripts/size-report.sh"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.111",
    "@iconify/tailwind4": "^1.2.3",
    "@tailwindcss/cli": "^4.3.0",
    "daisyui": "^5.0.0"
  }
}
